# Local API defaults. Copy to apps/api/.env for local development.
# Do not commit real secrets.

AIPPT_APP_ENV=development
AIPPT_DATABASE_URL=sqlite:///./aippt.db
AIPPT_SESSION_SECRET=change-me-in-production
AIPPT_SESSION_COOKIE_NAME=aippt_session
AIPPT_OAUTH_STATE_COOKIE_NAME=aippt_oauth_state
AIPPT_SECURE_COOKIES=false
AIPPT_JOBS_ROOT=/srv/aippt/jobs
AIPPT_BUILDER_COMMAND=aippt-build

# Hermes/MiMo deep planning. Keep provider keys in the Hermes profile or server
# environment, never in browser code or committed files.
AIPPT_HERMES_PLANNER_ENABLED=false
AIPPT_HERMES_COMMAND=hermes
AIPPT_HERMES_PROVIDER=
AIPPT_HERMES_MODEL=
AIPPT_HERMES_TOOLSETS=memory
AIPPT_HERMES_SKILLS=aippt-sjtu-ppt
AIPPT_HERMES_PLAN_TIMEOUT_SECONDS=300
AIPPT_HERMES_AUTO_BUILD_AFTER_PLAN=true

# jAccount OAuth2
# Register at https://developer.sjtu.edu.cn/
AIPPT_JACCOUNT_CLIENT_ID=
AIPPT_JACCOUNT_CLIENT_SECRET=
AIPPT_JACCOUNT_REDIRECT_URI=http://127.0.0.1:8000/api/auth/jaccount/callback
AIPPT_JACCOUNT_AUTHORIZE_URL=https://jaccount.sjtu.edu.cn/oauth2/authorize
AIPPT_JACCOUNT_TOKEN_URL=https://jaccount.sjtu.edu.cn/oauth2/token
AIPPT_JACCOUNT_USERINFO_URL=https://api.sjtu.edu.cn/v1/me/profile
AIPPT_JACCOUNT_SCOPE=basic

# Development only. In development this is enabled automatically; keep disabled
# in production by setting AIPPT_APP_ENV=production.
AIPPT_DEV_ALLOW_FAKE_LOGIN=false
